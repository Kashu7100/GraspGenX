<?xml version="1.0" ?>
<robot name="hand">
  <link name="hand_x_link"/>
  <link name="hand_y_link"/>
  <link name="hand_z_link"/>
  <link name="hand_spherical_link"/>
  <joint name="hand_x_joint" type="prismatic">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="hand_x_link"/>
    <child link="hand_y_link"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="10.0"/>
    <limit lower="-100.0" upper="100.0" effort="200.0" velocity="1.0"/>
